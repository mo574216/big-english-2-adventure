{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/course-structure.schema.json",
  "title": "English Adventure 2 Curriculum Structure",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "course",
    "units",
    "checkpoints",
    "starters_practice"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_on": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "course": {
      "type": "object"
    },
    "units": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": [
          "id",
          "number",
          "type",
          "title",
          "vocabulary",
          "grammar",
          "outcomes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "number": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "type": {
            "enum": [
              "welcome",
              "unit"
            ]
          },
          "title": {
            "type": "string"
          },
          "vocabulary": {
            "type": "array"
          },
          "grammar": {
            "type": "array"
          },
          "outcomes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3
    },
    "starters_practice": {
      "type": "object"
    },
    "global_product_requirements": {
      "type": "object"
    }
  }
}
